# Server
PORT=3000
BASE_URL=http://localhost:3000
# Number of trusted reverse proxies in front of the app (0 = none/local).
# NEVER set this to a blanket "true" — clients could spoof X-Forwarded-For and defeat rate limiting.
TRUST_PROXY=0

# Database (single local SQLite file; parent dir is auto-created)
DATABASE_PATH=./data/urls.db

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20
GLOBAL_RATE_LIMIT_MAX=300

# Malicious-URL screening
#   local        -> no-network heuristic (default; always works, even behind a blocking proxy)
#   safebrowsing -> Google Safe Browsing v4 lookup (opt-in)
SCREENING_PROVIDER=local
# When the external screener errors/times out: true = allow (fail-open), false = block (fail-closed)
SCREENING_FAIL_OPEN=true
# Required only when SCREENING_PROVIDER=safebrowsing.
# WARNING: Safe Browsing v4 is deprecated (sunset 2027-03-31) and licensed for NON-COMMERCIAL use only.
# Commercial use (e.g. Cognizant) must use the paid Web Risk API instead. A human must own enabling this.
SAFE_BROWSING_API_KEY=
